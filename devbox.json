{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.10.7/.schema/devbox.schema.json",
  "packages": [
    "fluxcd@2.8.8",
    "kubectl@1.36.1",
    "oci-cli@3.85.0",
    "kubernetes-helm-wrapped@3.20.2",
    "pre-commit@4.5.1",
    "kustomize@5.8.1",
    "python312Packages.ruamel-yaml@0.18.14",
    "k9s@0.50.18",
    "velero@1.18.0",
    "age@1.3.1",
    "lychee@0.24.1",
    "sops@3.13.1",
    "kubeconform@0.7.0",
    "grafanactl@0.1.10"
  ],
  "shell": {
    "init_hook": [
      "source <(flux completion zsh)"
    ],
    "scripts": {
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ],
      "validate": [
        "kubeconform -strict -ignore-missing-schemas -summary -schema-location default -schema-location 'https://raw.githubusercontent.com/datreeio/CRDs-catalog/main/{{.Group}}/{{.ResourceKind}}_{{.ResourceAPIVersion}}.json' -verbose"
      ]
    }
  }
}
